  // ============ Game State ============
  const state = {
    difficulty: 'easy',
    questions: [],
    currentIdx: 0,
    score: 0,
    correct: 0,
    streak: 0,
    playsLeft: 3,
    timer: null,
    timeLeft: 0,
    answered: false
  };

  const DIFFICULTY_CONFIG = {
    easy: { count: 10, options: 3, time: 0, pointsPerCorrect: 10, pool: ['cat','dog','cow','pig','bird','frog','snake','lion','rain','thunder','wind','ocean'] },
    medium: { count: 11, options: 4, time: 0, pointsPerCorrect: 15, pool: ['piano','guitar','drum','violin','flute','trumpet','xylophone','bell','harp','saxophone','tambourine'] },
    hard: { count: 14, options: 4, time: 8, pointsPerCorrect: 20, pool: ['alarm','phone_ring','doorbell','heartbeat','whistle','clap','siren','clock_tick','laugh','footstep','paper_tear','door_knock','cat','dog','bird'] }
  };

  // ============ Game Logic ============
  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function buildQuestions(difficulty) {
    const cfg = DIFFICULTY_CONFIG[difficulty];
    const pool = cfg.pool;
    const selected = shuffle(pool).slice(0, Math.min(cfg.count, pool.length));

    return selected.map(key => {
      const wrongs = shuffle(pool.filter(k => k !== key)).slice(0, cfg.options - 1);
      const options = shuffle([key, ...wrongs]);
      return { correct: key, options };
    });
  }

  function startGame(difficulty) {
    state.difficulty = difficulty;
    state.questions = buildQuestions(difficulty);
    state.currentIdx = 0;
    state.score = 0;
    state.correct = 0;
    state.streak = 0;

    document.getElementById('start-screen').classList.add('hidden');
    document.getElementById('result-screen').classList.add('hidden');
    document.getElementById('game-screen').classList.remove('hidden');
    document.getElementById('total-q').textContent = state.questions.length;

    loadQuestion();
  }

  function loadQuestion() {
    if (state.currentIdx >= state.questions.length) {
      endGame();
      return;
    }

    state.answered = false;
    state.playsLeft = 3;
    const q = state.questions[state.currentIdx];
    const sound = SOUNDS[q.correct];

    // Update UI
    document.getElementById('current-q').textContent = state.currentIdx + 1;
    document.getElementById('score-display').textContent = state.score;
    document.getElementById('streak-display').textContent = state.streak;
    document.getElementById('streak-fire').classList.toggle('hidden', state.streak < 3);
    document.getElementById('plays-left').textContent = state.playsLeft;
    document.getElementById('category-badge').textContent = sound.category;
    document.getElementById('progress-bar').style.width = `${(state.currentIdx / state.questions.length) * 100}%`;
    document.getElementById('feedback').classList.add('hidden');

    // Reset play button
    const playBtn = document.getElementById('play-btn');
    playBtn.disabled = false;
    playBtn.classList.add('play-btn-glow');
    playBtn.innerHTML = '<i data-lucide="play" class="w-12 h-12 md:w-14 md:h-14 text-white ml-1"></i>';

    // Build options
    const grid = document.getElementById('options-grid');
    grid.innerHTML = '';
    q.options.forEach(key => {
      const s = SOUNDS[key];
      const btn = document.createElement('button');
      btn.className = 'option-btn bg-white/10 border-2 border-white/20 rounded-2xl p-4 md:p-5 text-left flex items-center gap-3';
      btn.innerHTML = `
        <span class="text-3xl md:text-4xl">${s.emoji}</span>
        <span class="font-display text-base md:text-lg">${s.name}</span>
      `;
      btn.addEventListener('click', () => handleAnswer(key, btn));
      grid.appendChild(btn);
    });

    lucide.createIcons();

    // Timer for hard mode
    const cfg = DIFFICULTY_CONFIG[state.difficulty];
    if (cfg.time > 0) {
      state.timeLeft = cfg.time;
      document.getElementById('timer-display').textContent = state.timeLeft + 's';
      document.getElementById('timer-display').classList.remove('text-red-400');
      document.getElementById('timer-display').classList.add('text-blue-300');

      clearInterval(state.timer);
      state.timer = setInterval(() => {
        state.timeLeft--;
        const td = document.getElementById('timer-display');
        td.textContent = state.timeLeft + 's';
        if (state.timeLeft <= 3) {
          td.classList.remove('text-blue-300');
          td.classList.add('text-red-400');
        }
        if (state.timeLeft <= 0) {
          clearInterval(state.timer);
          if (!state.answered) handleAnswer(null, null); // time out
        }
      }, 1000);
    } else {
      document.getElementById('timer-display').textContent = '∞';
    }

    // Auto play first time
    setTimeout(() => playCurrentSound(), 400);
  }

  function animateWave(playing) {
    document.querySelectorAll('.wave-bar').forEach((bar, i) => {
      if (playing) {
        bar.classList.add('playing');
        bar.style.animationDelay = (i * 0.05) + 's';
      } else {
        bar.classList.remove('playing');
        bar.style.height = '8px';
      }
    });
  }

  function playCurrentSound() {
    if (state.playsLeft <= 0 || state.answered) return;
    const q = state.questions[state.currentIdx];
    const sound = SOUNDS[q.correct];
    sound.play();
    state.playsLeft--;
    document.getElementById('plays-left').textContent = state.playsLeft;

    animateWave(true);
    setTimeout(() => animateWave(false), 2500);

    if (state.playsLeft <= 0) {
      document.getElementById('play-btn').classList.remove('play-btn-glow');
    }
  }

  function handleAnswer(selectedKey, btnEl) {
    if (state.answered) return;
    state.answered = true;
    clearInterval(state.timer);

    const q = state.questions[state.currentIdx];
    const isCorrect = selectedKey === q.correct;
    const cfg = DIFFICULTY_CONFIG[state.difficulty];

    // Disable all option buttons & mark correct/wrong
    document.querySelectorAll('.option-btn').forEach(b => {
      b.disabled = true;
      const label = b.querySelector('.font-display').textContent;
      if (label === SOUNDS[q.correct].name) b.classList.add('correct');
    });
    if (btnEl && !isCorrect) btnEl.classList.add('wrong');

    // Disable play
    const playBtn = document.getElementById('play-btn');
    playBtn.disabled = true;
    playBtn.classList.remove('play-btn-glow');

    // Feedback
    const fb = document.getElementById('feedback');
    fb.classList.remove('hidden');
    if (isCorrect) {
      let pts = cfg.pointsPerCorrect;
      // Streak bonus
      state.streak++;
      if (state.streak >= 3) pts += 5;
      if (state.streak >= 5) pts += 5;
      // Play count bonus (fewer plays = more points)
      if (state.playsLeft === 2) pts += 3;
      if (state.playsLeft === 1) pts += 1;

      state.score += pts;
      state.correct++;

      fb.className = 'mt-6 p-4 rounded-xl text-center fade-in bg-green-500/20 border border-green-400/40';
      fb.innerHTML = `<div class="font-display text-xl text-green-300 mb-1">✓ BENAR! +${pts} poin</div>
        <div class="text-sm text-green-100/80">${state.streak >= 3 ? '🔥 Streak ' + state.streak + '!' : ''}</div>`;

      playCorrectSfx();

      const sd = document.getElementById('score-display');
      sd.textContent = state.score;
      sd.classList.add('score-pop');
      setTimeout(() => sd.classList.remove('score-pop'), 500);

      if (state.streak >= 3) spawnConfetti(20);
    } else {
      state.streak = 0;
      fb.className = 'mt-6 p-4 rounded-xl text-center fade-in bg-red-500/20 border border-red-400/40';
      const msg = selectedKey === null ? 'Waktu habis!' : 'Salah!';
      fb.innerHTML = `<div class="font-display text-xl text-red-300 mb-1">✗ ${msg}</div>
        <div class="text-sm text-red-100/80">Jawaban: <strong>${SOUNDS[q.correct].emoji} ${SOUNDS[q.correct].name}</strong></div>`;
      playWrongSfx();
    }

    // Next button
    setTimeout(() => {
      fb.innerHTML += `<button id="next-btn" class="mt-3 px-6 py-2 rounded-full bg-white/20 hover:bg-white/30 font-semibold text-sm transition-all">
        ${state.currentIdx + 1 >= state.questions.length ? 'Lihat Hasil →' : 'Soal Berikutnya →'}
      </button>`;
      document.getElementById('next-btn').addEventListener('click', () => {
        state.currentIdx++;
        loadQuestion();
      });
    }, 1200);
  }

  function playCorrectSfx() {
    playTone({freq: 523.25, duration: 0.1, type: 'sine', vol: 0.2});
    playTone({freq: 659.25, duration: 0.1, delay: 0.1, type: 'sine', vol: 0.2});
    playTone({freq: 783.99, duration: 0.2, delay: 0.2, type: 'sine', vol: 0.2});
  }
  function playWrongSfx() {
    playTone({freq: 200, freqEnd: 100, duration: 0.3, type: 'sawtooth', vol: 0.2});
  }

  function spawnConfetti(count) {
    const colors = ['#f472b6', '#a78bfa', '#60a5fa', '#fbbf24', '#34d399'];
    for (let i = 0; i < count; i++) {
      const c = document.createElement('div');
      c.className = 'confetti';
      c.style.left = Math.random() * 100 + '%';
      c.style.background = colors[Math.floor(Math.random() * colors.length)];
      c.style.animationDuration = (2 + Math.random() * 2) + 's';
      c.style.borderRadius = Math.random() > 0.5 ? '50%' : '0';
      document.body.appendChild(c);
      setTimeout(() => c.remove(), 4000);
    }
  }

  function endGame() {
    clearInterval(state.timer);
    document.getElementById('game-screen').classList.add('hidden');
    document.getElementById('result-screen').classList.remove('hidden');

    const total = state.questions.length;
    const acc = Math.round((state.correct / total) * 100);

    document.getElementById('final-score').textContent = state.score;
    document.getElementById('final-correct').textContent = `${state.correct}/${total}`;
    document.getElementById('final-accuracy').textContent = acc + '%';

    let icon = '🎉', title = 'Hebat!', sub = 'Kerja bagus, teruskan!';
    if (acc === 100) { icon = '🏆'; title = 'SEMPURNA!'; sub = 'Kamu adalah Sound Master sejati!'; spawnConfetti(60); }
    else if (acc >= 80) { icon = '🌟'; title = 'Luar Biasa!'; sub = 'Telinga kamu sangat tajam!'; spawnConfetti(40); }
    else if (acc >= 60) { icon = '👍'; title = 'Bagus!'; sub = 'Terus berlatih untuk jadi master!'; }
    else if (acc >= 40) { icon = '💪'; title = 'Lumayan!'; sub = 'Coba lagi dan tingkatkan skormu!'; }
    else { icon = '🎧'; title = 'Jangan Menyerah!'; sub = 'Setiap master pernah jadi pemula!'; }

    document.getElementById('result-icon').textContent = icon;
    document.getElementById('result-title').textContent = title;
    document.getElementById('result-subtitle').textContent = sub;

    lucide.createIcons();
  }

  // ============ Event Listeners ============
  document.querySelectorAll('[data-difficulty]').forEach(btn => {
    btn.addEventListener('click', () => {
      getCtx(); // unlock audio on user gesture
      startGame(btn.dataset.difficulty);
    });
  });

  document.getElementById('play-btn').addEventListener('click', playCurrentSound);

  document.getElementById('play-again-btn').addEventListener('click', () => {
    startGame(state.difficulty);
  });

  document.getElementById('home-btn').addEventListener('click', () => {
    document.getElementById('result-screen').classList.add('hidden');
    document.getElementById('game-screen').classList.add('hidden');
    document.getElementById('start-screen').classList.remove('hidden');
  });
</script>
