  <script>
  // ============ Element SDK ============
  const defaultConfig = {};
  window.elementSdk && window.elementSdk.init({
    defaultConfig,
    onConfigChange: async () => {},
    mapToCapabilities: () => ({ recolorables: [], borderables: [], fontEditable: undefined, fontSizeable: undefined }),
    mapToEditPanelValues: () => new Map()
  });

  lucide.createIcons();

  // ============ Audio Engine (Web Audio API) ============
  let audioCtx = null;
  function getCtx() {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    if (audioCtx.state === 'suspended') audioCtx.resume();
    return audioCtx;
  }

  // Enhanced audio with compressor for clarity
  let masterGain = null;
  let compressor = null;
  
  function setupAudioChain() {
    const ctx = getCtx();
    if (!masterGain) {
      masterGain = ctx.createGain();
      masterGain.gain.value = 0.7;
      compressor = ctx.createDynamicsCompressor();
      compressor.threshold.value = -24;
      compressor.knee.value = 30;
      compressor.ratio.value = 12;
      compressor.attack.value = 0.003;
      compressor.release.value = 0.25;
      masterGain.connect(compressor);
      compressor.connect(ctx.destination);
    }
    return masterGain;
  }

  // Generic tone helper with better clarity
  function playTone({freq, type='sine', duration=0.5, delay=0, vol=0.3, freqEnd=null, filterFreq=null}) {
    const ctx = getCtx();
    const chain = setupAudioChain();
    const now = ctx.currentTime + delay;
    
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    const envelope = ctx.createGain();
    
    osc.type = type;
    osc.frequency.setValueAtTime(freq, now);
    if (freqEnd !== null) osc.frequency.exponentialRampToValueAtTime(Math.max(1, freqEnd), now + duration);
    
    gain.gain.value = vol;
    
    envelope.gain.setValueAtTime(0, now);
    envelope.gain.linearRampToValueAtTime(1, now + 0.03);
    envelope.gain.exponentialRampToValueAtTime(0.01, now + duration - 0.05);
    envelope.gain.linearRampToValueAtTime(0, now + duration);

    let node = osc;
    if (filterFreq) {
      const filter = ctx.createBiquadFilter();
      filter.type = 'lowpass';
      filter.frequency.value = filterFreq;
      filter.Q.value = 1;
      osc.connect(filter);
      filter.connect(gain);
    } else {
      osc.connect(gain);
    }
    gain.connect(envelope);
    envelope.connect(chain);
    
    osc.start(now);
    osc.stop(now + duration + 0.05);
  }

  function playNoise({duration=0.5, delay=0, vol=0.2, filterFreq=1000, filterType='lowpass'}) {
    const ctx = getCtx();
    const chain = setupAudioChain();
    const now = ctx.currentTime + delay;
    
    const bufferSize = ctx.sampleRate * duration;
    const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
    const data = buffer.getChannelData(0);
    
    // Better noise generation
    for (let i = 0; i < bufferSize; i++) {
      data[i] = Math.random() * 2 - 1;
    }
    
    const noise = ctx.createBufferSource();
    noise.buffer = buffer;
    
    const filter = ctx.createBiquadFilter();
    filter.type = filterType;
    filter.frequency.value = filterFreq;
    filter.Q.value = 0.5;
    
    const gain = ctx.createGain();
    gain.gain.value = vol;
    
    const envelope = ctx.createGain();
    envelope.gain.setValueAtTime(0, now);
    envelope.gain.linearRampToValueAtTime(1, now + 0.02);
    envelope.gain.exponentialRampToValueAtTime(0.01, now + duration - 0.05);
    envelope.gain.linearRampToValueAtTime(0, now + duration);
    
    noise.connect(filter);
    filter.connect(gain);
    gain.connect(envelope);
    envelope.connect(chain);
    
    noise.start(now);
    noise.stop(now + duration + 0.05);
  }

  // ============ Sound Library (Enhanced) ============
  const SOUNDS = {
    // ---- EASY: Animals & Nature ----
    cat: { name: 'Kucing', emoji: '🐱', category: 'Hewan', difficulty: 'easy', play() {
      playTone({freq: 1200, freqEnd: 800, duration: 0.35, type: 'sine', vol: 0.25, filterFreq: 2500});
      playTone({freq: 1100, freqEnd: 700, duration: 0.4, delay: 0.35, type: 'sine', vol: 0.25, filterFreq: 2500});
    }},
    dog: { name: 'Anjing', emoji: '🐶', category: 'Hewan', difficulty: 'easy', play() {
      for (let i = 0; i < 4; i++) {
        playTone({freq: 400, freqEnd: 200, duration: 0.2, delay: i * 0.28, type: 'square', vol: 0.3});
        playNoise({duration: 0.1, delay: i * 0.28 + 0.05, vol: 0.15, filterFreq: 1200});
      }
    }},
    cow: { name: 'Sapi', emoji: '🐄', category: 'Hewan', difficulty: 'easy', play() {
      playTone({freq: 150, freqEnd: 100, duration: 1.5, type: 'sine', vol: 0.3, filterFreq: 800});
    }},
    pig: { name: 'Babi', emoji: '🐷', category: 'Hewan', difficulty: 'easy', play() {
      for (let i = 0; i < 3; i++) {
        playNoise({duration: 0.15, delay: i * 0.3, vol: 0.2, filterFreq: 3000, filterType: 'bandpass'});
      }
    }},
    bird: { name: 'Burung', emoji: '🐦', category: 'Hewan', difficulty: 'easy', play() {
      for (let i = 0; i < 5; i++) {
        playTone({freq: 2200 + Math.random() * 1200, freqEnd: 1600, duration: 0.12, delay: i * 0.15, type: 'sine', vol: 0.2});
      }
    }},
    frog: { name: 'Katak', emoji: '🐸', category: 'Hewan', difficulty: 'easy', play() {
      for (let i = 0; i < 3; i++) {
        playTone({freq: 180, freqEnd: 120, duration: 0.25, delay: i * 0.4, type: 'square', vol: 0.3, filterFreq: 500});
      }
    }},
    snake: { name: 'Ular', emoji: '🐍', category: 'Hewan', difficulty: 'easy', play() {
      playNoise({duration: 0.6, vol: 0.2, filterFreq: 2000, filterType: 'bandpass'});
    }},
    lion: { name: 'Singa', emoji: '🦁', category: 'Hewan', difficulty: 'easy', play() {
      playTone({freq: 200, duration: 0.8, type: 'square', vol: 0.35, filterFreq: 1000});
      playNoise({duration: 0.5, delay: 0.3, vol: 0.2, filterFreq: 800});
    }},
    rain: { name: 'Hujan', emoji: '🌧️', category: 'Alam', difficulty: 'easy', play() {
      playNoise({duration: 2.2, vol: 0.18, filterFreq: 5000, filterType: 'highpass'});
    }},
    thunder: { name: 'Petir', emoji: '⚡', category: 'Alam', difficulty: 'easy', play() {
      playNoise({duration: 1.8, vol: 0.4, filterFreq: 300, filterType: 'lowpass'});
      playTone({freq: 50, duration: 1.5, type: 'sine', vol: 0.3, delay: 0.1});
    }},
    wind: { name: 'Angin', emoji: '💨', category: 'Alam', difficulty: 'easy', play() {
      playNoise({duration: 1.5, vol: 0.2, filterFreq: 2000, filterType: 'bandpass'});
    }},
    ocean: { name: 'Ombak Laut', emoji: '🌊', category: 'Alam', difficulty: 'easy', play() {
      playNoise({duration: 1.6, vol: 0.22, filterFreq: 800});
      playNoise({duration: 1.3, delay: 1.4, vol: 0.2, filterFreq: 700});
    }},

    // ---- MEDIUM: Instruments ----
    piano: { name: 'Piano', emoji: '🎹', category: 'Alat Musik', difficulty: 'medium', play() {
      const notes = [523.25, 659.25, 783.99];
      notes.forEach((f, i) => {
        playTone({freq: f, duration: 0.9, delay: i * 0.3, type: 'sine', vol: 0.25, filterFreq: 3500});
      });
    }},
