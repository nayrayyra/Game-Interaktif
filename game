    color: #fff;
    overflow-x: hidden;
  }
  .font-display { font-family: 'Bungee', cursive; letter-spacing: 0.02em; }

  /* Animated stars background */
  .stars::before, .stars::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(2px 2px at 20% 30%, #fff, transparent),
      radial-gradient(1px 1px at 60% 70%, #a78bfa, transparent),
      radial-gradient(1.5px 1.5px at 80% 20%, #fbbf24, transparent),
      radial-gradient(1px 1px at 40% 80%, #fff, transparent),
      radial-gradient(2px 2px at 90% 50%, #f472b6, transparent),
      radial-gradient(1px 1px at 10% 60%, #60a5fa, transparent);
    background-size: 200% 200%;
    pointer-events: none;
    z-index: 0;
    animation: twinkle 8s infinite;
  }
  .stars::after { animation-delay: -4s; opacity: 0.6; }
  @keyframes twinkle {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  /* Sound wave visualizer */
  .wave-bar {
    display: inline-block;
    width: 6px;
    margin: 0 2px;
    background: linear-gradient(180deg, #f472b6, #a78bfa, #60a5fa);
    border-radius: 3px;
    transform-origin: center;
  }
  .wave-bar.playing {
    animation: wave 0.6s ease-in-out infinite;
  }
  @keyframes wave {
    0%, 100% { height: 8px; }
    50% { height: 60px; }
  }

  /* Pulsing play button */
  .play-btn-glow {
    box-shadow: 0 0 0 0 rgba(244, 114, 182, 0.7);
    animation: pulse-ring 2s infinite;
  }
  @keyframes pulse-ring {
    0% { box-shadow: 0 0 0 0 rgba(244, 114, 182, 0.7); }
    70% { box-shadow: 0 0 0 30px rgba(244, 114, 182, 0); }
    100% { box-shadow: 0 0 0 0 rgba(244, 114, 182, 0); }
  }

  .option-btn {
    transition: all 0.2s ease;
    backdrop-filter: blur(10px);
  }
  .option-btn:hover:not(:disabled) {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(167, 139, 250, 0.4);
  }
  .option-btn.correct {
    background: linear-gradient(135deg, #10b981, #059669) !important;
    border-color: #34d399 !important;
    animation: correct-bounce 0.6s;
  }
  .option-btn.wrong {
    background: linear-gradient(135deg, #ef4444, #dc2626) !important;
    border-color: #f87171 !important;
    animation: shake 0.5s;
  }
  @keyframes correct-bounce {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.08); }
  }
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-8px); }
    75% { transform: translateX(8px); }
  }

  .fade-in { animation: fadeIn 0.5s ease-out; }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .score-pop {
    animation: scorePop 0.5s ease-out;
  }
  @keyframes scorePop {
    0% { transform: scale(1); }
    50% { transform: scale(1.3); color: #fbbf24; }
    100% { transform: scale(1); }
  }

  .streak-fire {
    animation: flicker 0.8s infinite;
  }
  @keyframes flicker {
    0%, 100% { transform: scale(1) rotate(-2deg); }
    50% { transform: scale(1.1) rotate(2deg); }
  }

  .confetti {
    position: fixed;
    width: 10px;
    height: 10px;
    top: -10px;
    pointer-events: none;
    z-index: 100;
    animation: fall linear forwards;
  }
  @keyframes fall {
    to { transform: translateY(110%) rotate(720deg); opacity: 0; }
  }

  .level-badge {
    background: linear-gradient(135deg, rgba(167, 139, 250, 0.2), rgba(244, 114, 182, 0.2));
    border: 1px solid rgba(167, 139, 250, 0.4);
  }

  .difficulty-card {
    transition: all 0.3s;
    backdrop-filter: blur(10px);
  }
  .difficulty-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 20px 40px rgba(167, 139, 250, 0.3);
